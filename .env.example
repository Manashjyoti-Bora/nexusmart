# MongoDB Atlas connection string (free tier works perfectly)
# Get it from: cloud.mongodb.com → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/nexusmart

# Secret for signing JWT tokens — any long random string (32+ chars)
# Generate one: openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-secret-string

# Email of the account that becomes admin on signup
ADMIN_EMAIL=manashjyotibora122@gmail.com
